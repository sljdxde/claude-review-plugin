{
  "name": "codex-claude-review",
  "version": "0.1.6",
  "type": "module",
  "description": "Codex plugin for read-only Claude Code reviews. Review working tree changes and branch diffs directly from Codex.",
  "license": "MIT",
  "keywords": [
    "codex",
    "claude",
    "claude-code",
    "plugin",
    "review",
    "code-review",
    "code-analysis",
    "static-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sljdxde/claude-review-plugin.git"
  },
  "homepage": "https://github.com/sljdxde/claude-review-plugin#readme",
  "bugs": {
    "url": "https://github.com/sljdxde/claude-review-plugin/issues"
  },
  "bin": {
    "claude-review": "bin/claude-review.mjs"
  },
  "files": [
    "bin/",
    "plugins/claude-review/scripts/",
    "plugins/claude-review/prompts/",
    "plugins/claude-review/schemas/",
    "plugins/claude-review/skills/",
    "plugins/claude-review/commands/",
    "plugins/claude-review/.codex-plugin/",
    ".agents/"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "prepublishOnly": "npm test",
    "version": "npm test"
  },
  "engines": {
    "node": ">=22"
  }
}
